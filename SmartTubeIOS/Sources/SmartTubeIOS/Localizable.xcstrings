        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Su qualsiasi dispositivo, apri il link qui sotto e inserisci il codice."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "任意のデバイスで以下のリンクを開き、コードを入力してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "모든 기기에서 아래 링크를 열고 코드를 입력하세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
