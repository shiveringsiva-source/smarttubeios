    "Skip — auto-skips. Show Toast — shows a skip button. Nothing — plays through." : {
      "comment" : "SponsorBlock settings section footer explaining the three action options",
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تخطي — يتخطى تلقائيًا. إظهار الزر — يعرض زر تخطي. لا شيء — يُشغَّل كاملًا."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Überspringen — überspringt automatisch. Schaltfläche — zeigt eine Überspringen-Schaltfläche an. Nichts — spielt durch."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Saltar — salta automáticamente. Mostrar aviso — muestra un botón de saltar. Nada — reproduce sin saltar."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Passer — passe automatiquement. Afficher le bouton — affiche un bouton de passage. Rien — lit normalement."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "छोड़ें — स्वतः छोड़ता है। बटन दिखाएं — छोड़ें बटन दिखाता है। कुछ नहीं — सामान्य रूप से चलाता है।"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Preskoči — automatsko preskakanje. Prikaži tost — prikazuje gumb za preskakanje. Ništa — svira."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lewati — melewati otomatis. Tampilkan Notifikasi — menampilkan tombol lewati. Tidak ada — diputar normal."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Salta — salta automaticamente. Mostra avviso — mostra un pulsante salta. Niente — riproduce normalmente."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "スキップ — 自動スキップ。スキップボタンを表示 — スキップボタンを表示。なし — そのまま再生。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "건너뛰기 — 자동으로 건너뜁니다. 버튼 표시 — 건너뛰기 버튼을 표시합니다. 없음 — 그냥 재생됩니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pular — pula automaticamente. Mostrar aviso — exibe um botão de pular. Nada — reproduz normalmente."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Пропустить — автоматический пропуск. Показать кнопку — отображает кнопку пропуска. Ничего — воспроизводить."
          }
        },
        "sr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Прескочи — аутоматски прескаче. Прикажи здравицу — приказује дугме за прескакање. Ништа — игра се."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Atla — otomatik atlar. Bildirim Göster — atlama düğmesi gösterir. Hiçbir şey — normal oynatır."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "跳过 — 自动跳过。显示提示 — 显示跳过按钮。无操作 — 正常播放。"
          }
        }
      }
    },
