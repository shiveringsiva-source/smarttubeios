    "Diagnostic Report sends recent app logs to the developer to help investigate issues." : {
      "comment" : "Settings about section footer explaining the diagnostic report feature",
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يرسل تقرير التشخيص سجلات التطبيق الأخيرة إلى المطور للمساعدة في التحقيق في المشكلات."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Diagnosebericht sendet aktuelle App-Protokolle an den Entwickler, um bei der Problemuntersuchung zu helfen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El informe de diagnóstico envía registros recientes de la app al desarrollador para ayudar a investigar problemas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le rapport de diagnostic envoie les journaux récents de l'application au développeur pour l'aider à résoudre les problèmes."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "डायग्नोस्टिक रिपोर्ट समस्याओं की जांच में मदद करने के लिए हाल के ऐप लॉग डेवलपर को भेजती है।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Laporan Diagnostik mengirimkan log aplikasi terbaru ke pengembang untuk membantu menyelidiki masalah."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il rapporto diagnostico invia i log recenti dell'app allo sviluppatore per aiutare a indagare sui problemi."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "診断レポートは最近のアプリログを開発者に送信して、問題の調査を支援します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "진단 보고서는 문제 조사를 돕기 위해 최근 앱 로그를 개발자에게 전송합니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O relatório de diagnóstico envia os registros recentes do app ao desenvolvedor para ajudar a investigar problemas."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Диагностический отчёт отправляет последние журналы приложения разработчику для анализа проблем."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tanılama Raporu, sorunların araştırılmasına yardımcı olmak için son uygulama günlüklerini geliştiriciye gönderir."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "诊断报告将最近的应用日志发送给开发者，以协助排查问题。"
          }
        }
      }
    },
