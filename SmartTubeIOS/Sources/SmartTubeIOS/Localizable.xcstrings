          }
        }
      }
    },
    "On this device, tap the button below — the sign-in page opens with your code already filled in." : {
      "comment" : "Sign-in activation screen subtitle (iOS/macOS) — prompts user to tap the primary link button",
      "extractionState" : "manual"
    },
    "Open a channel and tap \"Exclude from SponsorBlock\" to add it here." : {
      "comment" : "SponsorBlock excluded-channels empty state description",
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "افتح قناة واضغط على \"استثناء من SponsorBlock\" لإضافتها هنا."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Öffne einen Kanal und tippe auf \"Von SponsorBlock ausschließen\", um ihn hier hinzuzufügen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abre un canal y pulsa \"Excluir de SponsorBlock\" para añadirlo aquí."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ouvrez une chaîne et appuyez sur \"Exclure de SponsorBlock\" pour l'ajouter ici."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "कोई चैनल खोलें और यहाँ जोड़ने के लिए \"SponsorBlock से बाहर करें\" टैप करें।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Buka saluran dan ketuk \"Kecualikan dari SponsorBlock\" untuk menambahkannya di sini."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
