    "YouTube RSS feed URLs look like:\n**youtube.com/feeds/videos.xml?channel_id=…**\n\nYou can also find a channel's RSS feed via their channel page URL." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تبدو روابط خلاصات YouTube RSS هكذا:\n**youtube.com/feeds/videos.xml?channel_id=…**\n\nيمكنك أيضًا العثور على خلاصة RSS للقناة عبر رابط صفحة القناة."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "YouTube-RSS-Feed-URLs sehen so aus:\n**youtube.com/feeds/videos.xml?channel_id=…**\n\nDu kannst den RSS-Feed eines Kanals auch über die URL der Kanalseite finden."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las URL de feeds RSS de YouTube tienen este aspecto:\n**youtube.com/feeds/videos.xml?channel_id=…**\n\nTambién puedes encontrar el feed RSS de un canal a través de la URL de su página de canal."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les URL des flux RSS YouTube ressemblent à :\n**youtube.com/feeds/videos.xml?channel_id=…**\n\nVous pouvez aussi trouver le flux RSS d'une chaîne via l'URL de sa page de chaîne."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "YouTube RSS फ़ीड URL इस प्रकार दिखते हैं:\n**youtube.com/feeds/videos.xml?channel_id=…**\n\nआप किसी चैनल का RSS फ़ीड उनके चैनल पेज URL से भी पा सकते हैं।"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "URL-ovi YouTube RSS kanala izgledaju ovako:\n**youtube.com/feeds/videos.xml?channel_id=…**\n\nRSS feed kanala možete pronaći i putem URL-a stranice kanala."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "URL feed RSS YouTube terlihat seperti:\n**youtube.com/feeds/videos.xml?channel_id=…**\n\nAnda juga dapat menemukan feed RSS saluran melalui URL halaman saluran mereka."
          }
        },
        "it" : {
          "stringUnit" : {
