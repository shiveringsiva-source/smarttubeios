{
  "sourceLanguage" : "en",
  "strings" : {
    "" : {

    },
    "\"%@\" has been saved to your Photos library." : {
      "comment" : "Download success alert message. %@ = video title.",
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تم حفظ \"%@\" في مكتبة الصور."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" wurde in deiner Fotomediathek gespeichert."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" se ha guardado en tu fototeca."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" a été enregistré dans votre photothèque."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" आपकी फ़ोटो लाइब्रेरी में सहेजा गया।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" telah disimpan ke perpustakaan Foto Anda."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" è stato salvato nella tua libreria foto."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「%@」が写真ライブラリに保存されました。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\"이(가) 사진 보관함에 저장되었습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" foi salvo na sua fototeca."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "«%@» сохранено в Фотографии."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" Fotoğraflar kitaplığınıza kaydedildi."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "《%@》已保存到您的照片图库。"
          }
        }
      }
    },
    "\"%@\" was added to your Watch Later playlist." : {

    },
