{
  "sourceLanguage" : "en",
  "strings" : {
    "" : {

    },
    "\"%@\" has been saved to your Photos library." : {
      "comment" : "Download success alert message. %@ = video title.",
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تم حفظ \"%@\" في مكتبة الصور."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" wurde in deiner Fotomediathek gespeichert."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" se ha guardado en tu fototeca."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" a été enregistré dans votre photothèque."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" आपकी फ़ोटो लाइब्रेरी में सहेजा गया।"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" je spremljen u vašu biblioteku fotografija."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" telah disimpan ke perpustakaan Foto Anda."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" è stato salvato nella tua libreria foto."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「%@」が写真ライブラリに保存されました。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\"이(가) 사진 보관함에 저장되었습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" foi salvo na sua fototeca."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "«%@» сохранено в Фотографии."
          }
        },
        "sr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "„%@“ је сачувано у вашој фототеци."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" Fotoğraflar kitaplığınıza kaydedildi."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "《%@》已保存到您的照片图库。"
          }
        }
      }
    },
    "\"%@\" was added to your Watch Later playlist." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تمت إضافة \"%@\" إلى قائمة المشاهدة لاحقاً."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" wurde zu deiner Wiedergabeliste „Später ansehen“ hinzugefügt."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" se ha añadido a tu lista para ver más tarde."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "« %@ » a été ajouté à votre liste de lecture ultérieure."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" आपकी बाद में देखें प्लेलिस्ट में जोड़ा गया।"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" je dodan na vaš popis za reprodukciju Gledajte kasnije."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" telah ditambahkan ke daftar putar Tonton Nanti Anda."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" è stato aggiunto alla playlist Da vedere in seguito."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「%@」がウォッチレータープレイリストに追加されました。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\"이(가) 나중에 볼 목록에 추가되었습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" foi adicionado à sua lista \"Assistir mais tarde\"."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "«%@» добавлено в список «Смотреть позже»."
          }
        },
        "sr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "„%@“ је додат на вашу плејлисту Гледајте касније."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" Daha Sonra İzle çalma listenize eklendi."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「%@」已添加到您的稍后观看播放列表。"
          }
        }
      }
    },
    "\"%@\" was removed from your Watch Later playlist." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تمت إزالة \"%@\" من قائمة التشغيل \"المشاهدة لاحقًا\"."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "„%@“ wurde aus Ihrer „Später ansehen“-Playlist entfernt."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" se eliminó de tu lista de reproducción Ver más tarde."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" a été supprimé de votre liste de lecture À regarder plus tard."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" को आपकी बाद में देखें प्लेलिस्ट से हटा दिया गया था।"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" je uklonjen s vašeg popisa za reprodukciju Gledajte kasnije."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" telah dihapus dari playlist Tonton Nanti Anda."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" è stato rimosso dalla tua playlist Guarda più tardi."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「%@」は、後で見るプレイリストから削除されました。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "'%@'가 나중에 볼 동영상 재생목록에서 삭제되었습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" foi removido da sua playlist Assistir mais tarde."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Песня \"%@\" была удалена из плейлиста \"Посмотреть позже\"."
          }
        },
        "sr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "„%@“ је уклоњено са плејлисте Гледајте касније."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" Daha Sonra İzle oynatma listenizden kaldırıldı."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@”已从您的“稍后观看”播放列表中删除。"
          }
        }
      }
    },
